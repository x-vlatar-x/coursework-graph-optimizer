<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="using:GraphOptimizer.Models"
             xmlns:enums="using:GraphOptimizer.Enums"
             xmlns:vm="using:GraphOptimizer.ViewModels"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="48"
             x:DataType="vm:HeaderViewModel"
             x:Class="GraphOptimizer.Views.HeaderView">

    <Border Classes="PanelCard" Padding="20 0" Height="54">
        <Grid RowDefinitions="*" ColumnDefinitions="Auto, *, Auto">
            <StackPanel Classes="HeaderButtons" Grid.Column="0" Orientation="Horizontal">
                <Button Name="SaveButton" Click="OnSaveProjectButtonClick">
                    <Grid ColumnDefinitions="24, Auto">
                        <Path Grid.Column="0" Data="{StaticResource SaveIconGeometry}"/>
                        <TextBlock Grid.Column="1">Зберегти</TextBlock>
                    </Grid>
                </Button>
                <Button Name="LoadButton" Click="OnLoadProjectButtonClick">
                    <Grid ColumnDefinitions="24, Auto">
                        <Path Grid.Column="0" Data="{StaticResource LoadIconGeometry}"/>
                        <TextBlock Grid.Column="1">Завантажити</TextBlock>
                    </Grid>
                </Button>
                <Button Name="ClearButton" Click="OnClearButtonClick">
                    <Grid ColumnDefinitions="24, Auto">
                        <Path Grid.Column="0" Data="{StaticResource ClearIconGeometry}"/>
                        <TextBlock Grid.Column="1">Очистити</TextBlock>
                    </Grid>
                </Button>
            </StackPanel>
            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Border Name="AnalysisModeList" 
                        Classes.expanded="{Binding IsAnalysisModeListExpanded}">
                    <FlyoutBase.AttachedFlyout>
                        <Flyout Placement="BottomEdgeAlignedLeft" IsOpen="{Binding IsAnalysisModeListExpanded, Mode=TwoWay}">
                            <Grid Width="{Binding #AnalysisModeList.Bounds.Width}">
                                <Border Classes="Liner"/>
                                <Border Classes="List">
                                    <StackPanel>
                                        <Button Classes="Item"
                                                Classes.selected="{Binding SelectedAnalysisMode, Converter={StaticResource EqualityConverter}, ConverterParameter=Greedy}"
                                                Tag="{x:Static enums:AnalysisMode.Greedy}"
                                                Click="OnAnalysisModeItemClick">Жадібний метод</Button>
                                        <Button Classes="Item"
                                                Classes.selected="{Binding SelectedAnalysisMode, Converter={StaticResource EqualityConverter}, ConverterParameter=Approx}"
                                                Tag="{x:Static enums:AnalysisMode.Approx}"
                                                Click="OnAnalysisModeItemClick">Метод Approx-Vertex-Cover</Button>
                                        <Button Classes="Item"
                                                Classes.selected="{Binding SelectedAnalysisMode, Converter={StaticResource EqualityConverter}, ConverterParameter=Backtracking}"
                                                Tag="{x:Static enums:AnalysisMode.Backtracking}"
                                                Click="OnAnalysisModeItemClick">Пошук з поверненням</Button>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Flyout>
                    </FlyoutBase.AttachedFlyout>
                    <Grid ColumnDefinitions="Auto, 24">
                        <TextBlock Name="SelectedAnalysisMode" Grid.Column="0" Text="{Binding SelectedAnalysisMode, Converter={StaticResource EnumToDescriptionConverter}, ConverterParameter='Оберіть метод розв\'язання'}"></TextBlock>
                        <Button Name="ExpandButton" Grid.Column="1" Click="OnAnalysisModeListExpandButtonClick">
                            <Grid>
                                <Path Name="Down" Data="{StaticResource ArrowDropDownIconGeometry}"/>
                                <Path Name="Up" Data="{StaticResource ArrowDropUpIconGeometry}"/>
                            </Grid>
                        </Button>
                    </Grid>
                </Border>
                <Button Name="ActionButton" Click="OnActionButtonClick">
                    <Grid>
                        <Path Name="Start" Data="{StaticResource StartIconGeometry}"/>
                        <Path Name="Stop" Data="{StaticResource StopIconGeometry}"/>
                    </Grid>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
