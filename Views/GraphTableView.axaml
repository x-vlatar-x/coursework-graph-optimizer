<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="using:GraphOptimizer.Models"
             xmlns:graphcore="using:GraphOptimizer.ViewModels.GraphCore"
             xmlns:vm="using:GraphOptimizer.ViewModels"
             mc:Ignorable="d" d:DesignWidth="200" d:DesignHeight="450"
             x:DataType="vm:GraphTableViewModel"
             x:Class="GraphOptimizer.Views.GraphTableView">

    <Border Classes="PanelCard">
        <Grid RowDefinitions="Auto, *, Auto" Margin="0 0 8 16">
            <Border Grid.Row="0" Classes="PanelTitle">
                <TextBlock>Список суміжності</TextBlock>
            </Border>
            <ScrollViewer Grid.Row="1" Classes="VerticesList" Classes.empty="{Binding GraphVM.Vertices, Converter={StaticResource CollectionEmptyConverter}}">
                <ItemsControl ItemsSource="{Binding GraphVM.Vertices}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Classes="VertexEntry" 
                                    Classes.expanded="{Binding IsExpanded}">
                                <StackPanel Orientation="Vertical">
                                    <Border Classes="VertexHeader">
                                        <Grid ColumnDefinitions="Auto, *, Auto" RowDefinitions="Auto, Auto">
								            <TextBlock Name="VertexId" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="{Binding Model.Id, StringFormat='\{0\} вершина'}"/>
								            <TextBlock Name="EdgeCount" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="{Binding EdgeCount, StringFormat='Суміжні вершини: \{0\}'}"/>
                                            <Button Name="ExpandButton" Grid.Row="0" Grid.RowSpan="2" Grid.Column="2" VerticalAlignment="Center" Click="OnExpandButtonClick">
									            <Grid>
										            <Path Classes="Down" Data="{StaticResource ArrowDropDownIconGeometry}"/>
										            <Path Classes="Up" Data="{StaticResource ArrowDropUpIconGeometry}"/>
                                                </Grid>
                                            </Button>
											<Border Name="DeleteButton" Grid.Row="0" Grid.RowSpan="2">
                                                <Button Click="OnVertexDeletePressed">
                                                    <Path Data="{StaticResource DeleteIconGeometry}"/>
                                                </Button>
                                            </Border>
                                        </Grid>
                                    </Border>
                                    <Border Classes="VertexDetails">
                                        <Grid RowDefinitions="Auto, Auto">
                                            <ScrollViewer Grid.Row="0" 
                                                          Classes="NeighborsList"
                                                          Classes.empty="{Binding Neighbors, Converter={StaticResource CollectionEmptyConverter}}">
                                                <ItemsControl ItemsSource="{Binding Neighbors}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <WrapPanel Margin="0 0 -8 -8"/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
										                <DataTemplate>
											                <Border Classes="Neighbor"
                                                                    PointerPressed="OnNeighborDeletePressed">
                                                                <Grid>
												                    <TextBlock Name="NeighborId" Text="{Binding Model.Id}"/>
																    <Path Data="{StaticResource CrossIconGeometry}"/>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>										
                                            </ScrollViewer>
                                            <Border Grid.Row="1" Classes="NeighborCreator">
												<!--<Grid RowDefinitions="Auto, Auto" ColumnDefinitions="Auto, *">
                                                    <TextBlock Name="Label" Grid.Row="0" Grid.Column="0">Додати зв'язок:</TextBlock>
                                                    <TextBlock Name="Clue" Grid.Row="1" Grid.Column="0">(введіть id вершини)</TextBlock>
                                                    <TextBox Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" 
                                                             Watermark="Id"
                                                             MaxLength="10"
                                                             TextChanged="OnIdTextChanged"/>
                                                    <Button></Button>
                                                </Grid>-->
                                                <Grid ColumnDefinitions="Auto, *, 24">
                                                    <TextBlock Name="Label" Grid.Column="0">Додати зв'язок:</TextBlock>
                                                    <StackPanel Grid.Column="1" Margin="12 0">
                                                        <TextBox Watermark="id вершини"
                                                                 MaxLength="10"
                                                                 Text="{Binding InputNeighborId}"
                                                                 TextChanged="OnIdTextChanged"/>
                                                    </StackPanel> 
                                                    <Button IsEnabled="{Binding IsIdValid}" Click="OnNeighborAddPressed" Grid.Column="2" Width="24" Height="24">
                                                        <Path Width="24" Height="24" VerticalAlignment="Center" HorizontalAlignment="Center" Stroke="#FFFFFF" StrokeThickness="1.5" Data="{StaticResource ValidIconGeometry}"/>
                                                    </Button>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
            <Button Grid.Row="2" HorizontalAlignment="Stretch" Cursor="Hand" Background="#1AFFFFFF" CornerRadius="8" Padding="12 12" Margin="12 0 4 -4" Click="OnVertexAddPressed">
				<StackPanel>
					<TextBlock FontSize="14">Додати вершину</TextBlock>
                </StackPanel>
            </Button>
        </Grid>
    </Border>

    <UserControl.Styles>
		<Style Selector="Border.VertexEntry">
		    <Setter Property="Background" Value="#1AFFFFFF"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12 0 12 0"/>
            <Setter Property="Margin" Value="32 0 8 8"/>
            <Setter Property="ClipToBounds" Value="False"/>
        </Style>
        
        <Style Selector="ScrollBar /template/ RepeatButton">
            <Setter Property="IsVisible" Value="False" />
        </Style>

        <Style Selector="ScrollViewer.VerticesList">
            <Setter Property="AllowAutoHide" Value="False"/>
			<Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="Padding" Value="0 0 0 0"/>
        </Style>

        <Style Selector="ScrollViewer.VerticesList ScrollBar:vertical">
			<Setter Property="Margin" Value="-6 0 -5 0"/>
        </Style>

        <Style Selector="ScrollViewer.VerticesList ScrollBar:vertical /template/ Rectangle#TrackRect">
            <Setter Property="IsVisible" Value="False" />
        </Style>

        <Style Selector="ScrollViewer.VerticesList ScrollBar:vertical /template/ Thumb">
			<Setter Property="Width" Value="4"/>
            <Setter Property="CornerRadius" Value="2"/>
            <Setter Property="Background" Value="#40FFFFFF"/>
        </Style>

        <Style Selector="Border.NeighborCreator">
			<Setter Property="Background" Value="#1AFFFFFF"/>
            <Setter Property="Padding" Value="12 8 12 8"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>

        <Style Selector="Border.NeighborCreator TextBlock#Label">
			<Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0 0 0 2"/>
            <Setter Property="FontSize" Value="14"/>
            <!--<Setter Property="Height" Value="18"/>-->
            <!--<Setter Property="LineHeight" Value="18"/>-->
        </Style>

        <!--<Style Selector="Border.NeighborCreator TextBlock#Clue">
			<Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0 2 0 0"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Height" Value="12"/>
            <Setter Property="LineHeight" Value="12"/>
            <Setter Property="Foreground" Value="#99FFFFFF"/>
        </Style>-->

        <Style Selector="Border.NeighborCreator TextBox">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>

            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            
			<Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Padding" Value="8 4"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style Selector="Border.NeighborCreator TextBox:pointerover /template/ Border#PART_BorderElement">
			<Setter Property="Background" Value="#1AFFFFFF"/>
        </Style>

        <Style Selector="Border.NeighborCreator TextBox:focus /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <!--VERTEX HEADER START-->
        <Style Selector="Border.VertexHeader">
		    <Setter Property="Padding" Value="8 6 0 6"/>
        </Style>

        <Style Selector="Border.VertexHeader TextBlock#VertexId">
			<Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style Selector="Border.VertexHeader TextBlock#EdgeCount">
			<Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#99FFFFFF"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style Selector="Border.VertexHeader Button#ExpandButton">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <Style Selector="Border.VertexHeader Button#ExpandButton Path">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Stroke" Value="White"/>
            <Setter Property="StrokeThickness" Value="2"/>
        </Style>

        <Style Selector="Border.VertexHeader Button#ExpandButton Path.Up">
            <Setter Property="Opacity" Value="0"/>
        </Style>

        <Style Selector="Border.VertexHeader Button#ExpandButton Path.Down">
            <Setter Property="Opacity" Value="1"/>
        </Style>

        <Style Selector="Border.expanded Button#ExpandButton Path.Up">
            <Setter Property="Opacity" Value="1"/>
        </Style>

        <Style Selector="Border.expanded Button#ExpandButton Path.Down">
            <Setter Property="Opacity" Value="0"/>
        </Style>

        <Style Selector="Border.VertexHeader Border#DeleteButton">
            <Setter Property="Width" Value="14"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="CornerRadius" Value="20 0 0 20"/>
            <Setter Property="Margin" Value="-34.5 0 0 0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Background" Value="#1AFFFFFF"/>
        </Style>

        <Style Selector="Border.VertexHeader Border#DeleteButton Button">
			<Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Background" Value="#1AFFFFFF"/>        
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style Selector="Border.VertexHeader Border#DeleteButton Button Path">
			<Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Stroke" Value="White"/>
            <Setter Property="StrokeThickness" Value="1"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>
        <!--VERTEX HEADER END-->
        
        <!--VERTEX DETAILS START-->
        <Style Selector="Border.VertexDetails">
			<Setter Property="MaxHeight" Value="0"/>
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="Padding" Value="0 4 0 12"/>
            <Setter Property="Transitions">
				<Transitions>
					<DoubleTransition Property="MaxHeight" Duration="0:0:0.2"/>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Border.expanded Border.VertexDetails">
			<Setter Property="MaxHeight" Value="170"/>
            <Setter Property="Opacity" Value="1"/>
        </Style>

        <Style Selector="ScrollViewer.NeighborsList">
            <Setter Property="AllowAutoHide" Value="False"/>
			<Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="MaxHeight" Value="95"/>
            <Setter Property="Margin" Value="0 0 0 8"/>
        </Style>

        <Style Selector="ScrollViewer.NeighborsList.empty">
			<Setter Property="Margin" Value="0"/>
        </Style>

         <Style Selector="ScrollViewer.NeighborsList ScrollBar:vertical /template/ Rectangle#TrackRect">
            <Setter Property="IsVisible" Value="False" />
        </Style>

        <Style Selector="ScrollViewer.NeighborsList ScrollBar:vertical /template/ Thumb">
			<Setter Property="Width" Value="4"/>
            <Setter Property="CornerRadius" Value="2"/>
            <Setter Property="Background" Value="#40FFFFFF"/>
        </Style>

        <Style Selector="Border.Neighbor">
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Margin" Value="0 0 8 8"/>
            <Setter Property="Padding" Value="12 0"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Background" Value="#1AFFFFFF"/>
        </Style>

        <Style Selector="Border.Neighbor:pointerover">
			<Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#33FFFFFF"/>
        </Style>

        <Style Selector="Border.Neighbor TextBlock#NeighborId">
			<Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
			<Setter Property="Opacity" Value="1"/>
        </Style>

        <Style Selector="Border.Neighbor Path">
			<Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Stroke" Value="White"/>
            <Setter Property="StrokeThickness" Value="1.5"/>
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="Margin" Value="-12 0"/>
        </Style>

        <Style Selector="Border.Neighbor:pointerover TextBlock#NeighborId">
			<Setter Property="Opacity" Value="0"/>
        </Style>

        <Style Selector="Border.Neighbor:pointerover Path">
			<Setter Property="Opacity" Value="1"/>
        </Style>
        <!--VERTEX DETAILS END-->
    </UserControl.Styles>
</UserControl>
