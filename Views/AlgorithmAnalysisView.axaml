<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="using:GraphOptimizer.Models"
             xmlns:vm="using:GraphOptimizer.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:DataType="vm:AlgorithmAnalysisViewModel"
             x:Class="GraphOptimizer.Views.AlgorithmAnalysisView">
    <Canvas Name="OverlayCanvas" Background="{x:Null}">
		<Border Name="Window"
                Classes.visible="{Binding AppState.IsAnalysisActive}"
                Canvas.Top="{Binding Y}"
                Canvas.Left="{Binding X}">
            <Border Name="WindowContent"
                    Classes.expanded="{Binding IsExpanded}">
                <Grid RowDefinitions="Auto, *">
					<Border Name="AnalysisHeader" Grid.Row="0">
						<Grid ColumnDefinitions="24, *, 24">
                            <Border Grid.Column="0" Margin="-4 2 4 0" Width="40"
                                    PointerMoved="OnDragBarPointerMoved"
                                    PointerPressed="OnDragBarPointerPressed"
                                    PointerReleased="OnDragBarPointerReleased">
								<Path Width="24" Height="24" Fill="#99FFC8FF" Data="{StaticResource MoveIconGeometry}"/>
                            </Border>
							<TextBlock Name="WindowTitle" Grid.Column="1">Результати аналізу</TextBlock>
                            <Button Name="ExpandButton" Grid.Column="2" Click="OnExpandButtonClick">
                                <Grid>
                                    <Path Name="Down" Data="{StaticResource ArrowDropDownIconGeometry}"/>
                                    <Path Name="Up" Data="{StaticResource ArrowDropUpIconGeometry}"/>
                                </Grid>
                            </Button>
                        </Grid>
                    </Border>
                    <Border Name="AnalysisDetails" Grid.Row="1">
						<Grid RowDefinitions="Auto, Auto, Auto, Auto" ColumnDefinitions="50*, 50*">
							<TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" HorizontalAlignment="Center" FontSize="14" Foreground="#FFC8FF" Text="{Binding Result.Mode, Converter={StaticResource EnumToDescriptionConverter}}"></TextBlock>
                            <TextBlock Grid.Row="1" Grid.Column="0" FontSize="14" Margin="0 4 0 0" Foreground="#CCFFC8FF" Text="Кількість вершин"></TextBlock>
                            <TextBlock Grid.Row="1" Grid.Column="1" FontSize="14" Margin="0 4 0 0" Foreground="#CCFFC8FF" Text="{Binding Result.VertexCount}"></TextBlock>
                            <TextBlock Grid.Row="2" Grid.Column="0" FontSize="14" Margin="0 4 0 0" Foreground="#CCFFC8FF" Text="Кількість операцій"></TextBlock>
                            <TextBlock Grid.Row="2" Grid.Column="1" FontSize="14" Margin="0 4 0 0" Foreground="#CCFFC8FF" Text="{Binding Result.OperationCount}"></TextBlock>
                            <TextBlock Grid.Row="3" Grid.Column="0" FontSize="14" Margin="0 4 0 0" Foreground="#CCFFC8FF" Text="Витрачено часу"></TextBlock>
                            <TextBlock Grid.Row="3" Grid.Column="1" FontSize="14" Margin="0 4 0 0" Foreground="#CCFFC8FF" Text="{Binding Result.FormattedTime}"></TextBlock>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Border>
    </Canvas>

    <UserControl.Styles>
		<Style Selector="Border#Window">
            <Setter Property="Width" Value="300"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="BoxShadow" Value="0 0 10 0 #4D000000"/>
            <Setter Property="Background">
				<RadialGradientBrush Center="50%,50%"
                                     GradientOrigin="100%,0%"
                                     RadiusX="100%"
                                     RadiusY="100%">
                    <GradientStop Color="#0748CC" Offset="0"/>
                    <GradientStop Color="#8200BE" Offset="1"/>
                </RadialGradientBrush>
            </Setter>
        </Style>

        <Style Selector="Window.analysis_mode Border#Window">
			<Setter Property="Opacity" Value="1"/>
        </Style>

        <Style Selector="Border#WindowContent">
            <Setter Property="Background" Value="#1AFFFFFF"/>
            <Setter Property="BorderBrush" Value="#4DFFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
			<Setter Property="CornerRadius" Value="12"/>
            <Setter Property="ClipToBounds" Value="True"/>
        </Style>

        <Style Selector="TextBlock#WindowTitle">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="#FFC8FF"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style Selector="Border#AnalysisHeader">
			<Setter Property="Height" Value="46"/>
            <Setter Property="Padding" Value="16 0"/>
        </Style>

        <Style Selector="Border#AnalysisHeader">
			<Setter Property="Height" Value="46"/>
            <Setter Property="Padding" Value="16 0"/>
        </Style>

        <Style Selector="Button#ExpandButton">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <Style Selector="Button#ExpandButton Path">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
			<Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24" />
            <Setter Property="Stroke" Value="#FFC8FF"/>
            <Setter Property="StrokeThickness" Value="1.5"/>
        </Style>

        <Style Selector="Button#ExpandButton Path#Up">
            <Setter Property="Opacity" Value="0"/>
        </Style>

        <Style Selector="Button#ExpandButton Path#Down">
            <Setter Property="Opacity" Value="1"/>
        </Style>

        <Style Selector="Border#WindowContent.expanded Button#ExpandButton Path#Up">
            <Setter Property="Opacity" Value="1"/>
        </Style>

        <Style Selector="Border#WindowContent.expanded Button#ExpandButton Path#Down">
            <Setter Property="Opacity" Value="0"/>
        </Style>

        <Style Selector="Border#AnalysisDetails">
			<Setter Property="Padding" Value="16 0 16 12"/>
            <Setter Property="MaxHeight" Value="0"/>
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="Transitions">
				<Transitions>
					<DoubleTransition Property="MaxHeight" Duration="0:0:0.2"/>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Border#WindowContent.expanded Border#AnalysisDetails">
            <Setter Property="MaxHeight" Value="108"/>
            <Setter Property="Opacity" Value="1"/>
        </Style>
    </UserControl.Styles>
</UserControl>
