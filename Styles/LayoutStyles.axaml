<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style Selector="Border.PanelCard">
	    <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="BorderBrush" Value="#4DFFFFFF"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Background" Value="#1AFFFFFF"/>
    </Style>

    <Style Selector="Border.PanelCardShadow">
	    <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Background" Value="#00000000"/>
        <Setter Property="BoxShadow" Value="0 0 10 0 #4D000000"/>
    </Style>

    <Style Selector="Border.PanelTitle">
        <Setter Property="Margin" Value="0 24 0 16"/>
    </Style>

    <Style Selector="Border.PanelTitle TextBlock">
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="Foreground" Value="#FFC8FF"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
</Styles>
